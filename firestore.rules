rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. ACCESO PÚBLICO (Catálogo, Blog, Banners, Ciudadelas)
    match /products/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /categories/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /blog_posts/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /banners/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /ciudadelas/{doc} { allow read: if true; allow write: if request.auth != null; }
    
    // 2. PEDIDOS (Invitados pueden crear, Admin gestiona)
    match /orders/{doc} {
      allow create: if true;
      allow read, write: if request.auth != null; 
    }
    
    // 3. CIERRES DE CAJA Y FINANZAS
    match /cash_closures/{doc} {
      allow read, write: if true;
    }
    
    match /monthly_finance/{doc} {
      allow read, write: if true;
    }

    // 4. DATOS ADMINISTRATIVOS
    match /expenses/{doc} { allow read, write: if request.auth != null; }
    match /suppliers/{doc} { allow read, write: if request.auth != null; }
    match /search_logs/{doc} { allow read, write: if request.auth != null; }
    match /users/{doc} { allow read, write: if request.auth != null; }
    
    // 5. SEGURIDAD ADICIONAL POR DEFECTO
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
